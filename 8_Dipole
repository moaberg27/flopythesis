# Model parameters
# Grid parameters
Lx = 5000
Ly = 5000
ncol = 100
nrow = 100
delr = Lx / ncol
delc = Ly / nrow
print(f"delr: {delr}, delc: {delc}")

# Layer parameters (single layer, 50 m thick)
nlay = 1
top = 50
botm = [0]

# Aquifer parameters (single-layer anisotropic conductivity)
k_x = 2.0
k_y = 2.0
k_z = 2.0
porosity = 0.3

# Circular active domain (inscribed circle inside the square model domain)
xc = (np.arange(ncol) + 0.5) * delr
yc = (np.arange(nrow) + 0.5) * delc
Xc, Yc = np.meshgrid(xc, yc)
circle_center_x = Lx / 2.0
circle_center_y = Ly / 2.0
circle_radius = min(Lx, Ly) / 2.0
active_circle_2d = (
    (Xc - circle_center_x) ** 2 + (Yc - circle_center_y) ** 2
) <= circle_radius**2
idomain = np.repeat(active_circle_2d[np.newaxis, :, :], nlay, axis=0).astype(int)

# Cells on the circular edge: active cells with at least one inactive 4-neighbor
padded = np.pad(active_circle_2d, pad_width=1, mode="constant", constant_values=False)
north = padded[:-2, 1:-1]
south = padded[2:, 1:-1]
west = padded[1:-1, :-2]
east = padded[1:-1, 2:]
circle_edge_2d = active_circle_2d & (~north | ~south | ~west | ~east)

# Boundary conditions
Q_well_extract = -5000
Q_well_inject = 5000
h1 = 100
h2 = 90
# Create the Simulation
exe_name = "mf6.exe"
sim = fp.mf6.MFSimulation(sim_name=modelname, 
                          version='mf6',
                          exe_name=exe_name,
                          sim_ws=modelws,
                          )

# Time discretization
tdis_rc = [(1.0, 1, 1.0)]
tdis = fp.mf6.ModflowTdis(
    sim,
    time_units="DAYS",
    perioddata=tdis_rc,
)

# Iterative model solution
ims = fp.mf6.ModflowIms(sim, 
                        complexity='SIMPLE',
                        inner_dvclose=1e-6,
)

# Groundwater Flow Model
gwf = fp.mf6.ModflowGwf(sim, 
                        modelname=modelname, 
                        model_nam_file=f"{modelname}.nam",
                        save_flows=True)

# ADD PACKAGES 
# Discretization
dis = fp.mf6.ModflowGwfdis(gwf,
                           length_units='METERS', 
                           nlay=nlay, 
                           nrow=nrow, 
                           ncol=ncol, 
                           delr=delr, 
                           delc=delc,
                           top=top, 
                           botm=botm,
                           idomain=idomain,
                           )

# Node property flow package
npf = fp.mf6.ModflowGwfnpf(gwf, 
                           save_specific_discharge=True,
                           icelltype=[1],
                           k=k_x,
                           k22=k_y,
                           k33=k_z,
                           )

# Initial Conditions
strt_2d = h1 + (h2 - h1) * (Xc / Lx)
strt = np.repeat(strt_2d[np.newaxis, :, :], nlay, axis=0)

ic = fp.mf6.ModflowGwfic(gwf, 
                         strt=strt,
                         )

# Specified Head Package
chd_spd = []
edge_rows, edge_cols = np.where(circle_edge_2d)
for k in range(nlay):
    for r, c in zip(edge_rows, edge_cols):
        # Split the circular edge into four quarters using the dominant coordinate.
        # Left/right quarters: fixed heads (h1/h2), upper/lower quarters: no-flow.
        dx = Xc[r, c] - circle_center_x
        dy = Yc[r, c] - circle_center_y
        if abs(dx) >= abs(dy):
            head_bc = h1 if dx < 0 else h2
            chd_spd.append([(k, int(r), int(c)), float(head_bc)])

# Top and bottom circular edge quarters are no-flow (no CHD assigned there).
no_flow_edge_2d = circle_edge_2d & (
    np.abs(Xc - circle_center_x) < np.abs(Yc - circle_center_y)
)

chd = fp.mf6.ModflowGwfchd(gwf, 
                           stress_period_data=chd_spd,
)


# Well Package
center_row = nrow // 2
center_col = ncol // 2
well_offset = 2
extract_well_rc = (center_row, center_col - well_offset)
inject_well_rc = (center_row, center_col + well_offset)

if not active_circle_2d[extract_well_rc[0], extract_well_rc[1]]:
    raise ValueError("Extraction well location is outside active circular domain.")
if not active_circle_2d[inject_well_rc[0], inject_well_rc[1]]:
    raise ValueError("Injection well location is outside active circular domain.")

well_spd = [
    [(0, extract_well_rc[0], extract_well_rc[1]), Q_well_extract],
    [(0, inject_well_rc[0], inject_well_rc[1]), Q_well_inject],
]

# Keep particle release points around the extraction well.
well_row_col = [extract_well_rc]

wel = fp.mf6.ModflowGwfwel(gwf,
                        stress_period_data=well_spd,
)

# Output control
oc = fp.mf6.ModflowGwfoc(gwf,
                         head_filerecord=f"{modelname}.hds",
                         budget_filerecord=f"{modelname}.cbb",
                         saverecord=[('HEAD', 'ALL'), ('BUDGET', 'ALL')],
                         printrecord=[('HEAD', 'LAST'), ('BUDGET', 'LAST')]
)

# Check input
